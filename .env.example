# =============================================================================
#  CazaSpamBot — plantilla de configuración
#  Copia este archivo a `.env` y rellena los valores. NUNCA commitees `.env`.
#    cp .env.example .env
#  Lo MÍNIMO para arrancar son las 2 variables de la sección "OBLIGATORIO".
#  Todo lo demás tiene valores por defecto razonables.
# =============================================================================


# =============================================================================
#  1) OBLIGATORIO
# =============================================================================

# --- Token del bot ---
# Créalo hablando con @BotFather en Telegram (/newbot). Te da un token tipo
# 1234567890:AAH... — pégalo aquí. El bot debe ser ADMIN en cada grupo a moderar
# (con permisos de banear y borrar mensajes).
TELEGRAM_BOT_TOKEN=

# --- Tu user_id (el admin del bot) ---
# Es el ÚNICO usuario con permisos de escritura (banear, aprender, configurar).
# Para saber tu id, escribe a cualquiera de estos bots y te lo dirán:
#   @userinfobot   ·   @getidsbot   ·   @myidbot   ·   @RawDataBot
# Pega aquí el número (ej. 123456789).
ADMIN_USER_ID=

# Chat donde recibir las notificaciones del bot (alertas, revisiones, etc.).
# Si lo dejas vacío, se usa tu ADMIN_USER_ID (DM directo del bot a ti). Recomendado vacío.
ADMIN_NOTIFY_CHAT_ID=


# =============================================================================
#  2) QUÉ CHATS MODERA
# =============================================================================

# CSV de chat_ids a moderar (ej. -1001234567890,-1009876543210).
# Para saber el chat_id de un grupo: añade @RawDataBot o @getidsbot al grupo,
# o reenvía un mensaje del grupo a @userinfobot.
# Si lo dejas VACÍO, el bot modera automáticamente TODOS los grupos donde sea
# admin (auto-discovery). Recomendado vacío salvo que quieras limitarlo.
MODERATED_CHAT_IDS=

# --- Modo de operación ---
# shadow = solo registra en la base de datos lo que HARÍA, no actúa (pruebas).
# active = ejecuta acciones reales (ban / kick / delete / mute).
# Empieza en shadow, revisa el log unos días, y cuando confíes pásalo a active.
MODE=shadow


# =============================================================================
#  3) TELETHON — OPCIONAL pero MUY RECOMENDABLE
# =============================================================================
# El bot funciona solo con la Bot API, pero Telegram NO deja que un bot lea la
# BIO/descripción ni las fotos de perfil de un usuario, ni enviar reportes
# oficiales de spam. Para eso se usa Telethon (MTProto) con una CUENTA DE
# USUARIO secundaria (NO tu cuenta personal: crea una aparte con otro número).
#
# Con Telethon activo se habilitan:
#   - bio_spam (detecta spam en la bio/descripción del perfil)
#   - photos_batch (detecta identidades robadas por ráfaga de fotos)
#   - reportes oficiales channels.reportSpam antes de banear
#   - lectura de admin_log (saber quién borró un mensaje)
#   - señales de perfil enriquecidas en las alertas al admin
#
# Si NO lo configuras, esas funciones simplemente NO se activan y el resto del
# bot sigue funcionando con normalidad. No rompe nada.
#
# Cómo obtener TG_API_ID / TG_API_HASH:
#   1. Entra en https://my.telegram.org con el número de la cuenta secundaria.
#   2. "API development tools" -> crea una app -> copia api_id y api_hash.
#   3. Autentica la sesión una vez con scripts/telethon_login.py
#      (genera data/telethon.session).

# Master switch. false = el bot va SOLO con Bot API (desactiva todo lo de arriba).
# Puedes apagarlo aquí en cualquier momento sin tocar el resto de la config.
TELETHON_ENABLED=true

TG_API_ID=
TG_API_HASH=
# Teléfono de la cuenta secundaria, formato internacional (ej. +34600111222).
# Solo se usa la primera vez, para generar la sesión.
TG_PHONE=

# Si true, antes de cada ban se envía un reporte oficial a Telegram vía Telethon.
# Sin sesión Telethon válida, se ignora silenciosamente.
REPORT_BEFORE_BAN=true
# Límite de reportes oficiales (protege la reputación de la cuenta secundaria).
REPORTER_RATE_PER_HOUR=20
REPORTER_RATE_PER_DAY=100


# =============================================================================
#  4) INTEGRACIONES OPCIONALES CON OTROS BOTS
# =============================================================================

# Bots de automatización cuyos borrados de mensajes NO son moderación y por
# tanto NO deben generar el aviso de "mensaje borrado manualmente". CSV de
# user_ids. Ej.: un bot que reemplaza enlaces de afiliados borra y repone el
# mensaje constantemente; es su función normal, no spam. (Para saber el id de
# un bot, reenvía uno de sus mensajes a @userinfobot.) Déjalo vacío si no aplica.
SKIP_DELETE_NOTIF_BOTS=

# --- Saludos simpáticos de bienvenida ---
# El bot saluda con una frase graciosa a los perfiles legítimos que entran.
# Las frases se editan en archivos de texto (una por línea), NO en código:
#   config/welcomes/generic.txt        -> saludo genérico (incluido de ejemplo)
#   config/welcomes/<chat_id>.txt      -> saludos temáticos de un grupo concreto
# Ver config/welcomes/README.md para el formato. Pon esto en false para
# desactivar los saludos del todo (los legítimos seguirán entrando sin verificar).
FRIENDLY_WELCOMES_ENABLED=true


# =============================================================================
#  5) BANS SINCRONIZADOS (FEDERACIÓN) Y POLÍTICA DE PRIMER MENSAJE
# =============================================================================

# Si true, un ban en CUALQUIER grupo se sincroniza a TODOS los demás del bot
# (la "federación" clásica de los bots de moderación).
FEDERATION_ENABLED=true

# Nº de mensajes iniciales de un usuario considerados "primeros" (reglas estrictas).
FIRST_MSG_WINDOW=3
# Scripts Unicode permitidos en primeros mensajes (CSV). Opciones: latin,
# cyrillic, arabic, hangul, han, hiragana, katakana, hebrew, greek, devanagari.
ALLOWED_SCRIPTS=latin
# Ratio mínimo de caracteres no permitidos para disparar (0.0 a 1.0).
NON_LATIN_RATIO_THRESHOLD=0.30
# Acción ante first-message-attack. Opciones: ban, kick, mute_24h, delete_only, shadow.
FIRST_MSG_ATTACK_ACTION=ban

# Mención @usuario o text_mention a alguien que NO está en el grupo -> score alto.
DETECT_EXTERNAL_MENTIONS=true
# Enlaces t.me/... a otros grupos/canales en el primer mensaje -> score alto.
DETECT_EXTERNAL_TG_LINKS=true

# Acortadores de URL bloqueados (CSV).
URL_BLOCKLIST=bit.ly,tinyurl.com,goo.gl,t.co,ow.ly,is.gd,buff.ly,rebrand.ly,cutt.ly,shorturl.at


# =============================================================================
#  6) DETECTORES VARIOS
# =============================================================================

# Reaction-farming: N reacciones en M segundos por un user con 0 mensajes previos.
REACTION_FARMING_ENABLED=true
REACTION_THRESHOLD_COUNT=5
REACTION_THRESHOLD_SECONDS=60

# Antiflood: FLOOD_MAX_MSGS mensajes en FLOOD_WINDOW_S segundos → mute de
# FLOOD_MUTE_HOURS horas + aviso público + botón "es/no es bot" al admin (la 1ª
# vez). Veteranos y usuarios marcados "no es bot" tienen más margen (umbral
# base +4 y +6). Reincidir = re-mute automático sin volver a preguntar.
FLOOD_MAX_MSGS=6
FLOOD_WINDOW_S=60
FLOOD_MUTE_HOURS=6

# CAS (Combot Anti-Spam): lista negra colaborativa. https://cas.chat
CAS_ENABLED=true
CAS_CACHE_TTL_SECONDS=86400
# Offenses mínimas para autoban sin revisión. 2 = solo si está confirmado en
# 2+ grupos (menos falsos positivos). Con menos, se notifica al admin para revisar.
CAS_AUTOBAN_MIN=2

# lols.bot: otra lista negra gratuita, complementaria a CAS.
LOLS_ENABLED=true

# Re-escanear mensajes editados (un user puede editar para colar spam tras entrar).
RESCAN_EDITED_MESSAGES=true


# =============================================================================
#  7) CLASIFICADOR LLM — OPCIONAL (desactivado por defecto)
# =============================================================================
# Capa extra opcional con un modelo de lenguaje. No es necesaria; el bot ya
# trae un clasificador local (Naive Bayes + similitud) sin coste.
LLM_ENABLED=false
LLM_PROVIDER=anthropic
LLM_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_API_KEY=


# =============================================================================
#  8) SCORING (umbrales de acción)
# =============================================================================
# Score acumulado de los detectores: >= BAN -> ban, >= KICK -> kick, >= MUTE -> mute.
BAN_SCORE=100
KICK_SCORE=70
MUTE_SCORE=40


# =============================================================================
#  9) QUIPS (mensaje sarcástico público al banear) — OPCIONAL
# =============================================================================
PUBLIC_QUIP_ENABLED=true
# Ban individual: el quip se borra a los N segundos. 3600 = 1h.
PUBLIC_QUIP_DELETE_AFTER_S=3600
# Bans en lote: 0 = no borrar nunca (queda como log público).
PUBLIC_QUIP_BATCH_DELETE_AFTER_S=0
# Si true, también pone quip en los bans automáticos (no solo en los manuales).
QUIP_ON_AUTO_BAN=false


# =============================================================================
#  10) NOTIFICACIONES EXTERNAS — OPCIONAL
# =============================================================================
# Reenviar alertas a través de un SEGUNDO bot de notificaciones (si ya tienes
# uno centralizado en tu servidor). La mayoría NO necesita esto: déjalo en false
# y el bot te avisa por su propio DM. Si lo activas, CASA_YONA_ENV_PATH apunta
# a un archivo .env con TG_BOT_TOKEN y TG_CHAT_ID de ese segundo bot.
NOTIFY_VIA_CASA_YONA=false
CASA_YONA_ENV_PATH=


# =============================================================================
#  11) BASE DE DATOS Y LOGS
# =============================================================================
DB_PATH=/app/data/antispam.db
LOG_LEVEL=INFO
